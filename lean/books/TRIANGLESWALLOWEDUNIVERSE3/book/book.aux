\newlabel{ch:3}{{3}{45}{Hyperbolic Shortcuts: How Pythagoras Learned to Factor}{chapter.3}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.1}The Puzzle of the Broken Square}{45}{section.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces A right triangle with legs labeled $21$ and $20$ and hypotenuse labeled $29$. On the leg of length $21$, a square of area $441$ is drawn. This square is visually "cracked" along a horizontal line into two rectangular pieces: a thin rectangle of dimensions $9 \times 49$ sitting below, and the crack line annotated with the equation $(29-20)\times (29+20) = 9 \times 49 = 441$. The numbers $3^2$ and $7^2$ appear faintly inside the two rectangles.}}{46}{figure.caption.28}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces A table with six rows and six columns. The columns are labeled $a$, $b$, $c$, $c - b$, $c + b$, and "Revealed factors of $a$." The rows contain the Pythagorean triples $(3,4,5)$, $(5,12,13)$, $(8,15,17)$, $(7,24,25)$, $(21,20,29)$, and $(9,40,41)$. The last column shows, for example, $\gcd (9, 21) = 3$ and $\gcd (1, 5) = 1$. Triples where the GCD reveals a nontrivial factor are highlighted in gold.}}{47}{figure.caption.29}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3.2}A Tree That Grows All Right Triangles}{48}{section.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces An elegant ternary tree, drawn to resemble an actual tree with organic branching. The root node is a circle containing $(3,4,5)$. Three branches descend, labeled $B_1$ (left), $B_2$ (middle), $B_3$ (right), leading to nodes $(5,12,13)$, $(21,20,29)$, $(15,8,17)$. Each of these has three children of its own, forming nine grandchild nodes. The full set of grandchildren: from $(5,12,13)$: $(7,24,25)$, $(55,48,73)$, $(45,28,53)$; from $(21,20,29)$: $(39,80,89)$, $(119,120,169)$, $(77,36,85)$; from $(15,8,17)$: $(33,56,65)$, $(65,72,97)$, $(35,12,37)$. The tree should feel lush and fractal, suggesting infinite continuation.}}{50}{figure.caption.30}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces A "zoom-in" panel showing the explicit matrix-vector multiplication $B_2 \times (3, 4, 5)^\top = (21, 20, 29)^\top $. The multiplication is laid out step by step in a decorative frame, with each row of the matrix dotted with the input vector and the partial sums shown. Below, the verification $21^2 + 20^2 = 29^2$ is displayed in a satisfying box.}}{51}{figure.caption.31}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3.3}The Light-Cone in the Living Room}{52}{section.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.5}{\ignorespaces A three-dimensional coordinate system with axes labeled $a$, $b$, $c$. A double cone (the "light cone") defined by $a^2 + b^2 = c^2$ opens upward and downward from the origin. The upper cone has several lattice points plotted on its surface, each marked with its coordinates: $(3,4,5)$ near the apex, $(5,12,13)$ and $(21,20,29)$ and $(15,8,17)$ further out. Dashed lines connect parent to child, retracing the edges of the Berggren tree. The cone's surface is semi-transparent, and a faint grid of integer lattice points fills the background, emphasizing that only a select few land exactly on the cone.}}{53}{figure.caption.32}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3.4}The Invariant That Refuses to Change}{54}{section.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces A whimsical cartoon of a photon (depicted as a small glowing orb with googly eyes and a mortarboard cap) standing at a blackboard. On the blackboard is written the equation $B_i^\top \mathbf  {Q}\, B_i = \mathbf  {Q}$, and underneath it, in the photon's handwriting: "This is why I always travel at the same speed." Caption: "Even light obeys the Berggren matrices."}}{55}{figure.caption.33}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces A flow diagram. A vector $(a, b, c)$ enters a "black box" labeled $B_2$ from the left. Above the input, a circular gauge with a needle pointing to $0$ is labeled "$Q$-meter." The vector emerges on the right as $(a + 2b + 2c,\tmspace  +\thickmuskip {.2777em} 2a + b + 2c,\tmspace  +\thickmuskip {.2777em} 2a + 2b + 3c)$. Above the output, an identical gauge also reads $0$. A banner across the top reads: "The Lorentz form is a conserved quantity." Below the diagram, a smaller example shows a non-null input $(1, 1, 0)$ with $Q = 2$ entering the same box and emerging with $Q$ still reading $2$.}}{56}{figure.caption.34}\protected@file@percent }
