\@writefile{lof}{\contentsline {figure}{\numberline {12.4}{\ignorespaces A vintage brass-and-mahogany mechanical device with four labelled input dials ($m$, $n$, $p$, $q$) on the left and four output displays ($a$, $b$, $c$, $d$) on the right. Interlocking gears connect the inputs to the outputs, with the parametric formulas inscribed on tiny brass placards beside each gear train. A worked example --- $m = 1$, $n = 0$, $p = 0$, $q = 1$ producing $(0, 2, 0, 2)$ --- is shown with red arrows tracing the signal path through the gears.}}{303}{figure.caption.171}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12.5}{\ignorespaces A number-line diagram showing $d$ as a single segment, decomposed into two coloured sub-segments: $m^2 + n^2$ (shaded blue) and $p^2 + q^2$ (shaded red). Each sub-segment is further subdivided into its two square components --- e.g., the blue region is split into $m^2$ (dark blue) and $n^2$ (light blue). Labels emphasise: "The hypotenuse is a sum of two sums-of-two-squares."}}{304}{figure.caption.172}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12.6}{\ignorespaces Two winding roads on a hilly landscape, each starting from a different village, converge on the same hilltop labelled $d^2 = 81$. The left road is marked with milestones $1$, $4$, $8$ (the components of the first quadruple); the right road with $4$, $4$, $7$. Where the roads meet, a magnifying glass hovers over the junction, revealing the number $15 = (c_1 - c_2)(c_1 + c_2)$. A small firefly labelled "$3$" --- the extracted prime factor --- escapes from under the glass.}}{305}{figure.caption.173}\protected@file@percent }
