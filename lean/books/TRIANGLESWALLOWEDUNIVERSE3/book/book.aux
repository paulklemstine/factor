\@writefile{toc}{\contentsline {section}{\numberline {13.1}The Eavesdropper's Puzzle}{317}{section.13.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13.1}{\ignorespaces A sealed envelope labeled "$p \times q = 4{,}579$" sits on a desk beside four numbered cards showing $a = 390$, $b = 1{,}738$, $c = 4{,}122$, $d = 4{,}579$. A magnifying glass hovers over the cards, and through its lens, the two primes $p$ and $q$ are faintly visible, as though the lens can decode them from the quadruple alone. Caption: "The eavesdropper's puzzle --- can four numbers betray two secrets?"}}{318}{figure.caption.181}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {13.2}Three Channels, One Tower}{319}{section.13.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {13.3}Cross-Channel Eavesdropping}{319}{section.13.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13.2}{\ignorespaces A tetrahedron whose four vertices are labeled $a$, $b$, $c$, $d$. The three edges connecting pairs among $\{a, b, c\}$ are drawn as thick colored cables --- red for $\mathrm  {Ch}_{ab} = a^2 + b^2$, blue for $\mathrm  {Ch}_{ac} = a^2 + c^2$, green for $\mathrm  {Ch}_{bc} = b^2 + c^2$. The apex vertex $d$ has dashed lines descending to each cable, labeled $d^2 - c^2$, $d^2 - b^2$, $d^2 - a^2$ respectively. A banner at the bottom reads: "Three channels, one hypotenuse --- sum: $2d^2$."}}{320}{figure.caption.182}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {13.4}The Prime Cascade}{321}{section.13.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13.3}{\ignorespaces A Venn diagram with three large overlapping circles labeled $\mathrm  {Ch}_{ab}$, $\mathrm  {Ch}_{ac}$, $\mathrm  {Ch}_{bc}$ in red, blue, and green respectively. In the pairwise intersection of the red and blue circles, show $b^2 - c^2$. In the red-green intersection, show $a^2 - c^2$. In the blue-green intersection, show $a^2 - b^2$. In the triple intersection at the center, show $2a^2, 2b^2, 2c^2$ stacked vertically. Title above the diagram: "The Triangulation Principle."}}{322}{figure.caption.183}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13.4}{\ignorespaces A "waterfall" or cascade diagram. At the top, two rectangular boxes labeled $\mathrm  {Ch}_{ab}$ and $\mathrm  {Ch}_{ac}$ pour their contents into a subtraction node, yielding a stream labeled $b^2 - c^2$. This stream hits a rock and splits into two waterfalls labeled $(b - c)$ and $(b + c)$. A glowing prime $p$, drawn as a smooth boulder, tumbles down and must fall into one waterfall or the other --- it cannot split. Caption: "Euclid's cascade --- a prime must choose a side."}}{323}{figure.caption.184}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {13.5}The Composite Tower}{324}{section.13.5}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {13.6}Even, Odd, and the Rule of Four}{324}{section.13.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13.5}{\ignorespaces A tall tower labeled $d = 35$ built from two colored brick layers: the bottom layer of $5$ blue bricks, the top layer of $7$ red bricks. Three spotlights from the base, labeled $\mathrm  {Ch}_{ab}$, $\mathrm  {Ch}_{ac}$, $\mathrm  {Ch}_{bc}$, shine upward at different angles, illuminating different sections of the tower. The $\mathrm  {Ch}_{ac}$ spotlight beam catches a glowing "$5$" embedded in the blue bricks, while the $\mathrm  {Ch}_{ab}$ beam illuminates a section with no visible factor. Caption: "A composite tower reveals its secret bricks --- but only to the right spotlight."}}{325}{figure.caption.185}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13.6}{\ignorespaces A $4 \times 4$ grid. Columns are labeled with the parity patterns of $(a, b, c)$: $(E,E,E)$, $(E,E,O)$, $(E,O,O)$, $(O,O,O)$ --- where $E$ = even, $O$ = odd. Rows are labeled $d$ even, $d$ odd. Cells are colored bright green (possible) or red with an "{$\times $}" (impossible). The cell for $(O,O,O)$ with $d$ even is prominently red. The cell for $(E,E,E)$ with $d$ odd is also red. Caption: "The Parity Chessboard of Pythagorean Quadruples --- only certain combinations survive the mod-$4$ sieve."}}{326}{figure.caption.186}\protected@file@percent }
