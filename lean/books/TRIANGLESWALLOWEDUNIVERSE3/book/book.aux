\@writefile{lof}{\contentsline {figure}{\numberline {12.1}{\ignorespaces A beautifully arranged table of the first fifteen primitive Pythagorean quadruples (those with $\gcd (a,b,c,d)=1$), sorted by $d$, displayed inside a stylised four-dimensional hypercube wireframe. Each quadruple is represented as a glowing point on the surface of a translucent three-sphere, with thin dotted lines radiating from the origin to each point. The table is inset at the lower-left of the diagram.}}{299}{figure.caption.168}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12.2}{\ignorespaces Side-by-side comparison. Left panel: a right triangle inscribed on a flat integer grid, legs $a$ and $b$, hypotenuse $c$, illustrating $a^2 + b^2 = c^2$. Right panel: a tetrahedron-like projection showing three orthogonal "leg" axes labelled $a$, $b$, $c$ meeting at the origin, with the point $(a, b, c)$ on a translucent sphere of radius $d$. A dashed radial line from the origin to the point is labelled $d$. Caption: "From triangles to spheres --- the Pythagorean equation in three and four dimensions."}}{300}{figure.caption.169}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12.3}{\ignorespaces A stone arch bridge spanning a river. On the left bank stands a translucent sphere labelled "$a^2 + b^2 + c^2 = d^2$" with the word "GEOMETRY" beneath. On the right bank, two parenthetical expressions $(d - c)$ and $(d + c)$ are connected by a multiplication sign, with the word "ARITHMETIC" beneath. The keystone of the arch is a large equals sign. Beneath the arch, a river flows carrying the symbols $a^2 + b^2$ on its current, connecting the two banks.}}{301}{figure.caption.170}\protected@file@percent }
