/-
Theorem 6.1: Existence of expansion in Dedekind domains (Neukirch Prop 6.1).
-/
/--
Theorem 6.1 (Neukirch): Let $\mathcal{O}$ be a Dedekind domain, $\mathfrak{p}$ a prime ideal, $\pi \in \mathfrak{p} \setminus \mathfrak{p}^2$.
Then every element of $\mathfrak{p}^i$ can be written as $a d + e$ where $d \in \mathcal{O}$ and $e \in \mathfrak{p}^{i+1}$.
This corresponds to `Ideal.exists_mul_add_mem_pow_succ` in Mathlib.
-/
theorem theorem_6_1 {S : Type*} [CommRing S] [IsDedekindDomain S]
    {P : Ideal S} [P.IsPrime] (hP : P ≠ ⊥)
    {i : ℕ} (a c : S) (a_mem : a ∈ P ^ i)
    (a_notMem : a ∉ P ^ (i + 1)) (c_mem : c ∈ P ^ i) :
    ∃ d : S, ∃ e ∈ P ^ (i + 1), a * d + e = c := by
  exact Ideal.exists_mul_add_mem_pow_succ hP a c a_mem a_notMem c_mem
